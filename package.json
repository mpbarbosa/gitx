{
  "name": "gitx",
  "version": "1.1.3",
  "description": "TypeScript Ink TUI App for git commands with MCP",
  "main": "./dist/index.js",
  "scripts": {
    "sync:pajussara": "node scripts/sync-pajussara-cdn.mjs",
    "dev": "npm run sync:pajussara && tsx src/index.tsx",
    "build": "npm run sync:pajussara && tsc -p tsconfig.json",
    "start": "npm run sync:pajussara && node dist/index.js",
    "lint": "npm run lint:js && npm run lint:md",
    "lint:js": "eslint src test scripts jest.config.mjs eslint.config.mjs",
    "lint:md": "markdownlint-cli2 \"**/*.md\" \"#node_modules\" \"#dist\" \"#vendor\" \"#.ai_workflow\"",
    "typecheck": "npm run sync:pajussara && tsc --noEmit -p tsconfig.json",
    "test": "npm run sync:pajussara && node --experimental-vm-modules ./node_modules/jest/bin/jest.js --runInBand"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/mpbarbosa/gitx.git"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "module",
  "bugs": {
    "url": "https://github.com/mpbarbosa/gitx/issues"
  },
  "homepage": "https://github.com/mpbarbosa/gitx#readme",
  "dependencies": {
    "ink": "^7.0.0",
    "react": "^19.2.5"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/jest": "^29.5.14",
    "@types/node": "^25.6.0",
    "@types/react": "^19.2.14",
    "eslint": "^10.2.0",
    "globals": "^17.5.0",
    "ink-testing-library": "^4.0.0",
    "jest": "^29.7.0",
    "jest-util": "^29.7.0",
    "markdownlint-cli2": "^0.22.0",
    "react-test-renderer": "^19.2.5",
    "ts-jest": "^29.4.9",
    "tsx": "^4.21.0",
    "typescript": "^6.0.2",
    "typescript-eslint": "^8.58.1"
  },
  "bin": {
    "gitx": "./dist/index.js"
  },
  "engines": {
    "node": ">=22"
  },
  "imports": {
    "#pajussara_tui_comp/DirectoryTextBrowser": "./vendor/pajussara_tui_comp/dist/src/DirectoryTextBrowser.js",
    "#pajussara_tui_comp/DirectoryTextBrowserWithStatusBar": "./vendor/pajussara_tui_comp/dist/src/DirectoryTextBrowserWithStatusBar.js",
    "#pajussara_tui_comp/StatusBar": "./vendor/pajussara_tui_comp/dist/src/StatusBar.js",
    "#pajussara_tui_comp/TextListPanel": "./vendor/pajussara_tui_comp/dist/src/TextListPanel.js"
  }
}
